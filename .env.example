# ---------------------------------------------------------------------------
# NQRust-LLMOps — frontend environment
# Copy to `.env.local` for local dev (Next.js loads it automatically).
# All vars are NEXT_PUBLIC_* because the browser talks to the backend directly.
# ---------------------------------------------------------------------------

# Base URL of the (vendored) Transformer Lab API server.
# Only used when NEXT_PUBLIC_USE_REAL_API=true.
NEXT_PUBLIC_TL_API_URL=http://localhost:8338

# Data source switch:
#   false (default) -> the whole UI runs on in-memory mock data (no backend needed)
#   true            -> services fetch from the real Transformer Lab API above
# Leave this off until the backend is running and CORS allows this origin.
NEXT_PUBLIC_USE_REAL_API=false

# ---------------------------------------------------------------------------
# Inference engine for the Interact chat (server-side BFF at /api/chat).
# Any OpenAI-compatible engine works — switching engines is just a URL change:
#   Ollama          -> http://localhost:11434/v1   (quick local test)
#   llama.cpp server -> http://localhost:8080/v1
#   Transformer Lab  -> http://localhost:8338/v1    (+ a real INFERENCE_API_KEY)
# ---------------------------------------------------------------------------
INFERENCE_BASE_URL=http://localhost:11434/v1
# Model name the engine expects (e.g. an Ollama tag). Can be overridden per-request from the UI.
INFERENCE_MODEL=qwen2.5:0.5b
# Bearer token: "dummy" is fine for Ollama/llama.cpp; set a real JWT for Transformer Lab.
INFERENCE_API_KEY=dummy
