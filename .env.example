# ---------------------------------------------------------------------------
# NQRust-LLMOps — environment (copy to .env.local; Next.js loads it automatically)
# Architecture (v0.40.0): Transformer Lab source backend (:8339) for
# orchestration + Ollama (:11434) for inference. See docs/SETUP.md.
# These are server-side (BFF) vars — not NEXT_PUBLIC.
# ---------------------------------------------------------------------------

# --- Transformer Lab orchestrator (train/eval/data/jobs). TL_ROOT is derived
#     from this by stripping the trailing /v1. ---
INFERENCE_BASE_URL=http://localhost:8339/v1
INFERENCE_API_KEY=tl-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INFERENCE_TEAM_ID=00000000-0000-0000-0000-000000000000

# --- Host runner for the serve/merge pipeline (export GGUF, merge-for-eval) ---
# Where the backend tooling (peft/llama.cpp/ollama) actually runs:
#   wsl    (default) — app on Windows shells into a WSL distro via wsl.exe
#   docker           — `docker exec` into the TL backend container
#   local            — run bash directly (app + tooling on the same *nix host)
HOST_RUNNER=wsl
# For HOST_RUNNER=wsl: the distro name (e.g. Ubuntu, Ubuntu-24.04).
WSL_DISTRO=Ubuntu
# For HOST_RUNNER=docker: the running TL backend container name.
DOCKER_CONTAINER=transformerlab

# --- Hugging Face Hub (the in-app "Hub" model/dataset browser) ---
# Optional. Public repos work without it; set a token to lift API rate limits
# and reach gated models. https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Ollama inference engine (chat + serving), the default engine ---
OLLAMA_BASE_URL=http://localhost:11434
# Default chat model (Ollama tag); overridable per-request from the UI.
INFERENCE_MODEL=qwen2.5:0.5b
# Ollama streams fine, so leave true for real SSE streaming.

# --- vLLM inference engine (second engine, full precision) ---
# The compose stack runs a `vllm` service; the frontend reaches it here. Leave the
# default when deploying the stack; set a custom /v1 only when pointing at an
# external vLLM. Unset entirely to turn vLLM off (Serve UI shows "not configured").
VLLM_BASE_URL=http://vllm:8000/v1
# Only if vLLM was launched with --api-key:
# VLLM_API_KEY=
#
# Which model the vLLM service serves. Either a Hugging Face id (default) or a
# LOCAL path to a merged fine-tune, e.g.
#   VLLM_MODEL=/root/.transformerlab/rantai_merged/eval-<your-finetune>
# (tl_data is mounted read-only into vLLM). Changing it needs a stack redeploy —
# vLLM serves one model per instance and cannot hot-swap like Ollama.
VLLM_MODEL=aisingapore/Qwen-SEA-LION-v4-8B-VL
VLLM_SERVED_NAME=qwen-sea-lion-v4-8b
# Fraction of GPU memory vLLM reserves (shared box → keep modest) and the context
# window (input+output tokens). 16384 leaves room for a full-length reply.
VLLM_GPU_UTIL=0.22
VLLM_MAX_MODEL_LEN=16384
INFERENCE_STREAM=true

# --- App access gate (optional shared password) ---
# Set to require a login for the whole app; leave empty to disable (local dev).
APP_PASSWORD=
# Per-deployment secret folded into the session token. Recommended when
# APP_PASSWORD is set: prevents a leaked cookie from being reduced to an offline
# password guess. Rotating it invalidates all sessions (forces re-login).
# Generate one, e.g.: openssl rand -hex 32
AUTH_SECRET=
