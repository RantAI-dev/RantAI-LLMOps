# ---------------------------------------------------------------------------
# NQRust-LLMOps — environment (copy to .env.local; Next.js loads it automatically)
# Architecture (v0.40.0): Transformer Lab source backend (:8339) for
# orchestration + Ollama (:11434) for inference. See docs/SETUP.md.
# These are server-side (BFF) vars — not NEXT_PUBLIC.
# ---------------------------------------------------------------------------

# --- Transformer Lab orchestrator (train/eval/data/jobs). TL_ROOT is derived
#     from this by stripping the trailing /v1. ---
INFERENCE_BASE_URL=http://localhost:8339/v1
INFERENCE_API_KEY=tl-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INFERENCE_TEAM_ID=00000000-0000-0000-0000-000000000000

# --- Ollama inference engine (chat + serving) ---
OLLAMA_BASE_URL=http://localhost:11434
# Default chat model (Ollama tag); overridable per-request from the UI.
INFERENCE_MODEL=qwen2.5:0.5b
# Ollama streams fine, so leave true for real SSE streaming.
INFERENCE_STREAM=true

# --- App access gate (optional shared password) ---
# Set to require a login for the whole app; leave empty to disable (local dev).
APP_PASSWORD=
